# TriageGuard environment — copy to .env and fill in.
# NEVER commit the real .env file. It is git-ignored.

# Required: Anthropic API key. Starts with sk-ant-.
# Preferred: source from macOS Keychain instead of writing here.
ANTHROPIC_API_KEY=

# Optional: GitHub token for higher WebFetch rate limits on api.github.com.
# Create a read-only PAT at https://github.com/settings/tokens.
GITHUB_TOKEN=

# Optional: NVD API key (skip for hackathon; public endpoint works).
# https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Hackathon deadline — already mirrored in .claude/settings.json.
TRIAGEGUARD_DEADLINE=2026-04-26T20:00:00-04:00
